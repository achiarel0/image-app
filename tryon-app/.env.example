# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this example IS committed as documentation.

# The n8n webhook that performs the image synthesis. Server-only (no
# NEXT_PUBLIC_ prefix) so it is never exposed to the browser.
WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/your-webhook-id

# Optional: max bytes per uploaded image (default 10 MB).
# MAX_UPLOAD_BYTES=10485760

# Supabase auth. These are intentionally NEXT_PUBLIC_: the URL and
# publishable key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# --- Payments (Stripe subscription) --------------------------------------
# ALL of these are server-only: no NEXT_PUBLIC_ prefix, ever.

# Stripe API secret key (test mode: sk_test_/rk_test_, live: sk_live_/rk_live_).
# Used to verify checkout sessions and subscription status server-side.
STRIPE_SECRET_KEY=sk_test_your_key

# Supabase secret (service role) key. Bypasses RLS and can update user
# app_metadata — never expose it or import lib/supabase/admin.ts client-side.
SUPABASE_SECRET_KEY=sb_secret_your_key

# The Stripe Payment Link users pay through, and its id (plink_...).
# The id is needed to look up completed checkout sessions for the
# "already subscribed" recheck. Test links start with buy.stripe.com/test_.
STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/test_your_link
STRIPE_PAYMENT_LINK_ID=plink_your_id
