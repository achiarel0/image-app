# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this example IS committed as documentation.

# The n8n webhook that performs the image synthesis. Server-only (no
# NEXT_PUBLIC_ prefix) so it is never exposed to the browser.
WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/your-webhook-id

# Optional: max bytes per uploaded image (default 10 MB).
# MAX_UPLOAD_BYTES=10485760

# Supabase auth. These are intentionally NEXT_PUBLIC_: the URL and
# publishable key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
